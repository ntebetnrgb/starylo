generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  trips     Trip[]
  reviews   Review[]
  bookings  Booking[]
  guide     Guide?
  rsvps     EventRSVP[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model City {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  country     String
  emoji       String
  description String
  history     String
  bestTime    String
  dailyBudget String
  currency    String?
  language    String?
  coverImage  String?
  createdAt   DateTime @default(now())

  spots  Spot[]
  trips  Trip[]
  guides Guide[]
  events Event[]
}

model Spot {
  id          String  @id @default(cuid())
  cityId      String
  name        String
  description String
  isHidden    Boolean @default(false)
  emoji       String?
  category    String?

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model Trip {
  id          String   @id @default(cuid())
  userId      String
  cityId      String?
  destination String
  description String?
  fromDate    DateTime
  toDate      DateTime
  budget      String   @default("mid-range")
  spotsTotal  Int      @default(4)
  spotsFilled Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  city   City?      @relation(fields: [cityId], references: [id])
  styles TripStyle[]
}

model TravelStyle {
  id    String @id @default(cuid())
  name  String @unique
  emoji String

  trips TripStyle[]
}

model TripStyle {
  tripId        String
  travelStyleId String

  trip        Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  travelStyle TravelStyle @relation(fields: [travelStyleId], references: [id])

  @@id([tripId, travelStyleId])
}

model Guide {
  id          String   @id @default(cuid())
  userId      String   @unique
  cityId      String
  bio         String
  specialties String
  hourlyRate  Float    @default(40)
  rating      Float    @default(5.0)
  reviewCount Int      @default(0)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  city     City      @relation(fields: [cityId], references: [id])
  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  guideId   String
  date      DateTime
  hours     Int      @default(3)
  status    String   @default("pending")
  message   String?
  total     Float
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide Guide @relation(fields: [guideId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  guideId   String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide Guide @relation(fields: [guideId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  cityId      String
  title       String
  description String
  venue       String?
  eventDate   DateTime
  artist      String?
  genre       String?
  isFree      Boolean  @default(true)
  maxRsvp     Int      @default(50)
  createdAt   DateTime @default(now())

  city  City        @relation(fields: [cityId], references: [id])
  rsvps EventRSVP[]
}

model EventRSVP {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}
